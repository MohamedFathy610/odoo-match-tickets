<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_match_user_form" model="ir.ui.view">
            <field name="name">match.user.form</field>
            <field name="model">match.user</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm_user" string="Confirm User" type="object" class="oe_highlight" invisible="state == 'confirmed'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="email"/>
                            </group>
                            <group>
                                <field name="phone_number"/>
                                <field name="password" password="True"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="User Bookings">
                                <field name="booking_ids" readonly="1">
                                    <tree decoration-info="status == 'draft'" decoration-success="status == 'confirmed'">
                                        <field name="booking_id"/>
                                        <field name="ticket_id"/>
                                        <field name="booking_time"/>
                                        <field name="status"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="My Credit Cards">
                                <field name="credit_card_ids">
                                    <tree editable="bottom">
                                        <field name="card_number"/>
                                        <field name="card_holder"/>
                                        <field name="expiry_date"/>
                                        <field name="cvv"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_match_user_tree" model="ir.ui.view">
            <field name="name">match.user.tree</field>
            <field name="model">match.user</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone_number"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'"/>
                </tree>
            </field>
        </record>

        <record id="view_match_user_search" model="ir.ui.view">
            <field name="name">match.user.search</field>
            <field name="model">match.user</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone_number"/>
                    <filter string="Confirmed Users" name="confirmed" domain="[('state','=','confirmed')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_match_user" model="ir.actions.act_window">
            <field name="name">Users</field>
            <field name="res_model">match.user</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="view_match_ticket_form" model="ir.ui.view">
            <field name="name">match.ticket.form</field>
            <field name="model">match.ticket</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm_ticket" string="Confirm Ticket" type="object" class="oe_highlight" invisible="state == 'confirmed'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="ticket_id"/>
                                <field name="destination"/>
                            </group>
                            <group>
                                <field name="departure_time"/>
                                <field name="price"/>
                                <field name="is_available"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Booked By">
                                <field name="booking_ids" readonly="1">
                                    <tree>
                                        <field name="user_id"/>
                                        <field name="booking_id"/>
                                        <field name="status"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_match_ticket_tree" model="ir.ui.view">
            <field name="name">match.ticket.tree</field>
            <field name="model">match.ticket</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ticket_id"/>
                    <field name="destination"/>
                    <field name="price"/>
                    <field name="is_available"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_match_ticket_search" model="ir.ui.view">
            <field name="name">match.ticket.search</field>
            <field name="model">match.ticket</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ticket_id"/>
                    <field name="destination"/>
                    <filter string="Available Tickets" name="available" domain="[('is_available','=',True)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_match_ticket" model="ir.actions.act_window">
            <field name="name">Tickets</field>
            <field name="res_model">match.ticket</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="view_match_booking_form" model="ir.ui.view">
            <field name="name">match.booking.form</field>
            <field name="model">match.booking</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm_booking" string="Confirm &amp; Pay" type="object" class="oe_highlight"/>
                        <field name="status" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="booking_id"/>
                                <field name="user_id"/>
                                <field name="ticket_id"/>
                            </group>
                            <group>
                                <field name="booking_time"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_match_booking_tree" model="ir.ui.view">
            <field name="name">match.booking.tree</field>
            <field name="model">match.booking</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="booking_id"/>
                    <field name="user_id"/>
                    <field name="ticket_id"/>
                    <field name="status"/>
                </tree>
            </field>
        </record>

        <record id="view_match_booking_search" model="ir.ui.view">
            <field name="name">match.booking.search</field>
            <field name="model">match.booking</field>
            <field name="arch" type="xml">
                <search>
                    <field name="booking_id"/>
                    <field name="user_id"/>
                    <field name="ticket_id"/>
                    <group expand="0" string="Group By">
                        <filter string="User" name="group_user" context="{'group_by':'user_id'}"/>
                        <filter string="Ticket" name="group_ticket" context="{'group_by':'ticket_id'}"/>
                        <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_match_booking" model="ir.actions.act_window">
            <field name="name">Bookings</field>
            <field name="res_model">match.booking</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="view_match_payment_form" model="ir.ui.view">
            <field name="name">match.payment.form</field>
            <field name="model">match.payment</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm_payment" string="Confirm Payment" type="object" class="oe_highlight" invisible="state == 'paid'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,paid"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="payment_id"/>
                                <field name="booking_id"/>
                                <field name="user_id" invisible="1"/>

                                <field name="payment_method" widget="radio"/>

                                <field name="credit_card_id"
                                       invisible="payment_method == 'cash'"
                                       required="payment_method == 'credit_card'"
                                       domain="[('user_id', '=', user_id)]"/>
                            </group>
                            <group>
                                <field name="discount_percentage"/>
                                <field name="amount"/>
                                <field name="payment_time"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_match_payment_tree" model="ir.ui.view">
            <field name="name">match.payment.tree</field>
            <field name="model">match.payment</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="payment_id"/>
                    <field name="booking_id"/>
                    <field name="amount"/>
                </tree>
            </field>
        </record>

        <record id="view_match_payment_search" model="ir.ui.view">
            <field name="name">match.payment.search</field>
            <field name="model">match.payment</field>
            <field name="arch" type="xml">
                <search>
                    <field name="payment_id"/>
                    <field name="booking_id"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_match_payment" model="ir.actions.act_window">
            <field name="name">Payments</field>
            <field name="res_model">match.payment</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="view_match_credit_card_form" model="ir.ui.view">
            <field name="name">match.credit_card.form</field>
            <field name="model">match.credit_card</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="user_id"/>
                                <field name="card_number"/>
                            </group>
                            <group>
                                <field name="card_holder"/>
                                <field name="expiry_date"/>
                                <field name="cvv"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_match_credit_card_tree" model="ir.ui.view">
            <field name="name">match.credit_card.tree</field>
            <field name="model">match.credit_card</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="user_id"/>
                    <field name="card_number"/>
                    <field name="card_holder"/>
                </tree>
            </field>
        </record>

        <record id="action_match_credit_card" model="ir.actions.act_window">
            <field name="name">Credit Cards</field>
            <field name="res_model">match.credit_card</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="view_partner_form_inherit_match" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.match</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="is_match_fan"/>
                    <field name="favorite_team" invisible="is_match_fan == False"/>
                </xpath>
            </field>
        </record>

        <record id="view_match_ticket_form_inherit" model="ir.ui.view">
            <field name="name">match.ticket.form.inherit</field>
            <field name="model">match.ticket</field>
            <field name="inherit_id" ref="view_match_ticket_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='destination']" position="after">
                    <field name="barcode"/>
                </xpath>
            </field>
        </record>

        <record id="view_match_ticket_vip_form" model="ir.ui.view">
            <field name="name">match.ticket.vip.form</field>
            <field name="model">match.ticket.vip</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm_ticket" string="Confirm VIP" type="object" class="oe_highlight" invisible="state == 'confirmed'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="ticket_id"/>
                                <field name="destination"/>
                                <field name="barcode"/>
                            </group>
                            <group>
                                <field name="departure_time"/>
                                <field name="price"/>
                                <field name="is_available"/>
                            </group>
                        </group>
                        <group string="VIP Features">
                            <field name="vip_lounge_access"/>
                            <field name="extra_services"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_match_ticket_vip_tree" model="ir.ui.view">
            <field name="name">match.ticket.vip.tree</field>
            <field name="model">match.ticket.vip</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ticket_id"/>
                    <field name="destination"/>
                    <field name="price"/>
                    <field name="vip_lounge_access"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="action_match_ticket_vip" model="ir.actions.act_window">
            <field name="name">VIP Tickets</field>
            <field name="res_model">match.ticket.vip</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="view_match_agent_form" model="ir.ui.view">
            <field name="name">match.agent.form</field>
            <field name="model">match.agent</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="email"/>
                                <field name="phone"/>
                            </group>
                            <group>
                                <field name="agent_code"/>
                                <field name="shift"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_match_agent_tree" model="ir.ui.view">
            <field name="name">match.agent.tree</field>
            <field name="model">match.agent</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="agent_code"/>
                    <field name="shift"/>
                </tree>
            </field>
        </record>

        <record id="action_match_agent" model="ir.actions.act_window">
            <field name="name">Agents</field>
            <field name="res_model">match.agent</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_match_root" name="Match Tickets" sequence="1"/>

        <menuitem id="menu_match_users" name="Users" parent="menu_match_root" action="action_match_user" sequence="10"/>
        <menuitem id="menu_match_ticket" name="Tickets" parent="menu_match_root" action="action_match_ticket" sequence="20"/>
        <menuitem id="menu_match_booking" name="Bookings" parent="menu_match_root" action="action_match_booking" sequence="30"/>
        <menuitem id="menu_match_payment" name="Payments" parent="menu_match_root" action="action_match_payment" sequence="40"/>
        <menuitem id="menu_match_credit_card" name="Credit Cards" parent="menu_match_root" action="action_match_credit_card" sequence="50"/>

        <menuitem id="menu_match_ticket_vip" name="VIP Tickets" parent="menu_match_root" action="action_match_ticket_vip" sequence="25"/>
        <menuitem id="menu_match_agent" name="Booking Agents" parent="menu_match_root" action="action_match_agent" sequence="15"/>

    </data>
</odoo>