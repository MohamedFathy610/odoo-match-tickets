<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ========================================== -->
        <!-- 0. شاشة إدخال بيانات الكريديت كارد (Popup) -->
        <!-- ========================================== -->
        <record id="view_match_credit_card_form" model="ir.ui.view">
            <field name="name">match.credit_card.form</field>
            <field name="model">match.credit_card</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="user_id" readonly="1" force_save="1" options="{'no_open': True}"/>
                                <field name="card_holder" placeholder="e.g. Ali Hassan"/>
                            </group>
                            <group>
                                <field name="card_number" placeholder="16 Digits"/>
                                <field name="expiry_date" placeholder="MM/YY"/>
                                <field name="cvv" password="True" placeholder="***"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ========================================== -->
        <!-- 1. شاشات المستخدم -->
        <!-- ========================================== -->
        <record id="view_match_user_form" model="ir.ui.view">
            <field name="name">match.user.form</field>
            <field name="model">match.user</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm_user" string="Confirm User" type="object" class="oe_highlight" invisible="state == 'confirmed'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="email"/>
                            </group>
                            <group>
                                <field name="phone_number"/>
                                <field name="password" password="True"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="User Bookings">
                                <field name="booking_ids" readonly="1">
                                    <tree decoration-info="status == 'draft'" decoration-success="status == 'confirmed'">
                                        <field name="booking_id"/>
                                        <field name="ticket_id"/>
                                        <field name="total_price"/>
                                        <field name="status"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_match_user_tree" model="ir.ui.view">
            <field name="name">match.user.tree</field>
            <field name="model">match.user</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone_number"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'"/>
                    <button name="unlink" type="object" icon="fa-trash" class="text-danger" title="Delete User" confirm="Are you sure you want to delete this user?"/>
                </tree>
            </field>
        </record>

        <record id="action_match_user" model="ir.actions.act_window">
            <field name="name">Users</field>
            <field name="res_model">match.user</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- ========================================== -->
        <!-- 2. شاشات التذاكر -->
        <!-- ========================================== -->
        <record id="view_match_ticket_form" model="ir.ui.view">
            <field name="name">match.ticket.form</field>
            <field name="model">match.ticket</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm_ticket" string="Confirm Ticket" type="object" class="oe_highlight" invisible="state == 'confirmed'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="ticket_id"/></h1>
                        </div>
                        <group>
                            <group string="Match Info">
                                <field name="home_team"/>
                                <field name="away_team"/>
                                <field name="match_name" readonly="1" force_save="1"/>
                                <field name="destination"/>
                                <field name="departure_time"/>
                            </group>
                            <group string="Pricing &amp; Details">
                                <field name="price" style="font-size: 16px; font-weight: bold;"/>
                                <field name="is_available" widget="boolean_toggle"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_match_ticket_tree" model="ir.ui.view">
            <field name="name">match.ticket.tree</field>
            <field name="model">match.ticket</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ticket_id"/>
                    <field name="match_name"/>
                    <field name="departure_time"/>
                    <field name="price"/>
                    <field name="is_available" widget="boolean_toggle"/>
                    <button name="unlink" type="object" icon="fa-trash" class="text-danger" title="Delete Ticket" confirm="Are you sure you want to delete this Ticket?"/>
                </tree>
            </field>
        </record>

        <record id="action_match_ticket" model="ir.actions.act_window">
            <field name="name">Tickets</field>
            <field name="res_model">match.ticket</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- ========================================== -->
        <!-- 3. شاشات الحجز -->
        <!-- ========================================== -->
        <record id="view_match_booking_form" model="ir.ui.view">
            <field name="name">match.booking.form</field>
            <field name="model">match.booking</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm_booking" string="Confirm &amp; Pay" type="object" class="oe_highlight" invisible="status != 'draft'"/>
                        <button name="action_cancel_booking" string="Cancel Booking" type="object" class="btn-danger" invisible="status != 'draft'" form_novalidate="1"/>

                        <button name="action_print_ticket" string="🖨️ Print Ticket" type="object" class="btn-success" invisible="status != 'confirmed'"/>

                        <field name="status" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="booking_id"/></h1>
                        </div>
                        <group>
                            <group string="Main Info">
                                <field name="user_id" domain="[('state', '=', 'confirmed')]" options="{'no_create': True, 'no_open': True}"/>
                                <field name="ticket_id" domain="[('is_available', '=', True)]" options="{'no_create': True, 'no_open': True}"/>
                                <field name="booking_time"/>
                            </group>
                            <group string="Payment &amp; Pricing">
                                <field name="payment_method" widget="radio" invisible="status != 'draft'"/>
                                <field name="credit_card_id"
                                       invisible="payment_method == 'cash'"
                                       required="payment_method == 'credit_card'"
                                       domain="[('user_id', '=', user_id)]"
                                       context="{'default_user_id': user_id}"
                                       options="{'no_open': True}"/>

                                <field name="is_vip" widget="boolean_toggle"/>
                                <field name="vip_fee" invisible="is_vip == False"/>
                                <field name="discount_percentage" style="color: blue;"/>
                                <field name="total_price" style="font-size: 18px; font-weight: bold; color: #008784;"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

       <record id="view_match_booking_tree" model="ir.ui.view">
            <field name="name">match.booking.tree</field>
            <field name="model">match.booking</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="booking_id"/>
                    <field name="user_id"/>
                    <field name="ticket_id"/>
                    <field name="is_vip"/>
                    <field name="total_price"/>

                    <field name="status" widget="badge"
                           decoration-info="status == 'draft'"
                           decoration-success="status == 'confirmed'"
                           decoration-danger="status == 'cancelled'"/>

                    <button name="unlink" type="object" icon="fa-trash" class="text-danger" title="Delete Booking" confirm="Are you sure you want to delete this booking?"/>
                </tree>
            </field>
        </record>

        <record id="action_match_booking" model="ir.actions.act_window">
            <field name="name">Bookings</field>
            <field name="res_model">match.booking</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- ========================================== -->
        <!-- 4. شاشات الدفع -->
        <!-- ========================================== -->
        <record id="view_match_payment_form" model="ir.ui.view">
            <field name="name">match.payment.form</field>
            <field name="model">match.payment</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm_payment" string="Confirm Payment" type="object" class="oe_highlight" invisible="state == 'paid'"/>

                        <button name="action_print_ticket" string="🖨️ Print Ticket" type="object" class="btn-success" invisible="state != 'paid'"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="payment_id"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="booking_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="user_id" invisible="1"/>
                                <field name="payment_method" widget="badge" decoration-success="payment_method == 'cash'" decoration-info="payment_method == 'credit_card'" readonly="1"/>
                                <field name="credit_card_id" invisible="payment_method == 'cash'" readonly="1" options="{'no_open': True}"/>
                            </group>
                            <group>
                                <field name="discount_percentage" style="color: green;" readonly="1"/>
                                <field name="amount" style="font-size: 18px; font-weight: bold;" readonly="1"/>
                                <field name="payment_time"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_match_payment_tree" model="ir.ui.view">
            <field name="name">match.payment.tree</field>
            <field name="model">match.payment</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="payment_id"/>
                    <field name="booking_id"/>
                    <field name="user_id" string="Customer"/>
                    <field name="payment_method"/>

                    <!-- شلنا الـ sum من هنا عشان الـ Total يختفي -->
                    <field name="amount"/>

                    <field name="state" widget="badge"
                           decoration-success="state == 'paid'"
                           decoration-info="state == 'draft'"/>
                    <button name="unlink" type="object" icon="fa-trash" class="text-danger"
                            title="Delete Payment" confirm="Are you sure you want to delete this Payment?"/>
                </tree>
            </field>
        </record>

        <record id="action_match_payment" model="ir.actions.act_window">
            <field name="name">Payments</field>
            <field name="res_model">match.payment</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- ========================================== -->
        <!-- 5. القوائم (Menus) -->
        <!-- ========================================== -->
        <menuitem id="menu_match_root" name="Match Tickets" sequence="1"/>
        <menuitem id="menu_match_users" name="Users" parent="menu_match_root" action="action_match_user" sequence="10"/>
        <menuitem id="menu_match_ticket" name="Tickets" parent="menu_match_root" action="action_match_ticket" sequence="20"/>
        <menuitem id="menu_match_booking" name="Bookings" parent="menu_match_root" action="action_match_booking" sequence="30"/>
        <menuitem id="menu_match_payment" name="Payments" parent="menu_match_root" action="action_match_payment" sequence="40"/>
    </data>
</odoo>